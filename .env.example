# ─── Usuario del host (evita problemas de permisos en volúmenes) ──────────────
# Obtener con: id -u
AIRFLOW_UID=1000

# ─── PostgreSQL externo ────────────────────────────────────────────────────────
# Datos de conexión al contenedor PostgreSQL independiente
# host.docker.internal porque Postgres corre en OTRO proyecto/contenedor,
# no hay servicio "postgres" en este docker-compose.
POSTGRES_HOST=host.docker.internal
POSTGRES_PORT=5432
POSTGRES_DB=airflow_db
POSTGRES_USER=airflow_user
POSTGRES_PASSWORD=123456

# ─── Airflow — Seguridad ───────────────────────────────────────────────────────
# Generar FERNET_KEY con:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=uklGqNdOmcmKLgQmcNtFkVMOJJRku9ix8cJ8kklled4=

# Cadena aleatoria segura (mínimo 16 caracteres)
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
AIRFLOW__WEBSERVER__SECRET_KEY=413abdd67a819b12aed1c9256fe6019275d534dd2b579371c804b94343ef0c9b

# ─── Usuario administrador inicial ────────────────────────────────────────────
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin123
